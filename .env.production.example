# Backend on Render
APP_NAME=Agency Task Platform
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://tasks.yourdomain.com

# Neon Postgres. You can paste Neon URLs as postgres:// or postgresql://;
# the backend normalizes them for psycopg.
DATABASE_URL=postgresql+psycopg://user:password@host/database?sslmode=require

# Cloudflare R2 or any S3-compatible storage
STORAGE_BACKEND=s3
STORAGE_AUTO_CREATE_BUCKET=false
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_BUCKET=task-attachments
S3_REGION=auto
MAX_UPLOAD_SIZE_MB=50

# Initial admin seeded on first deploy
ADMIN_NAME=Platform Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Frontend on Vercel
NEXT_PUBLIC_API_URL=https://your-render-api.onrender.com/api/v1
